@startuml
title Task State-Event Diagram

state "GitHub Issue (GH.Issue)" as GitHubIssue {
    [*] --> Open
    Open --> Closed : Issue closed (Webhook)
    Closed --> Open : Issue reopened (Webhook)
}

state "Jules Session (Jules.Session)" as JulesSession {
    [*] --> Created : triggerAgent()
    Created --> researching : STATE_RESEARCHING
    researching --> planning : STATE_PLANNING
    planning --> in_progress : STATE_IN_PROGRESS
    in_progress --> coding : STATE_CODING
    coding --> testing : STATE_TESTING
    testing --> finished : STATE_FINISHED / STATE_COMPLETED

    researching --> failed : STATE_FAILED / STATE_ERROR
    planning --> failed
    in_progress --> failed
    coding --> failed
    testing --> failed
}

state "GitHub Pull Request (GH.PR)" as PR {
    [*] --> None
    None --> OpenPR : PR created (polling/Webhook)
    OpenPR --> Merged : PR merged (Webhook)
    OpenPR --> ClosedPR : PR closed (Webhook)
    OpenPR --> ChecksPassed : Checks passed (Webhook)
    OpenPR --> ChecksFailed : Checks failed (Webhook)
}

state "Unified Task State" as Unified {
    [*] --> CREATED

    state PROCESSING {
        state ANALYZING #lightblue
        state PLANNING #lightblue
        state EXECUTING #yellow
        state VERIFYING #yellow
        state CHECKING #orange

        ANALYZING --> PLANNING
        PLANNING --> EXECUTING
        EXECUTING --> VERIFYING
        VERIFYING --> CHECKING : PR Created
    }

    CREATED --> ANALYZING : Jules starts researching
    CHECKING --> READY : Checks passed
    READY --> FINISHED : Issue closed / PR merged

    state FAILED {
        state FAILED_JULES #red
        state FAILED_PR #red
    }

    CREATED --> FAILED_JULES : Jules error
    PROCESSING --> FAILED_JULES : Jules error
    CHECKING --> FAILED_PR : PR checks fail
    READY --> FAILED_PR : New commit / checks fail

    state CREATED #lightgrey
    state READY #green
    state FINISHED #green
}

GitHubIssue -[dashed]-> Unified : influences
JulesSession -[dashed]-> Unified : maps to
PR -[dashed]-> Unified : influences

legend bottom
| **Unified State** | **Substate** | **Mapping Logic (Source States)** |
| CREATED | - | GH.Issue:open AND Jules.Session:none |
| PROCESSING | ANALYZING | Jules.Session:researching |
| | PLANNING | Jules.Session:planning OR Jules.Session:awaiting_plan_approval |
| | EXECUTING | Jules.Session:in-progress OR Jules.Session:coding |
| | VERIFYING | Jules.Session:testing |
| | CHECKING | Jules.Session:finished AND GH.PR:open AND GH.PR:checks_running |
| READY | - | Jules.Session:finished AND GH.PR:open AND GH.PR:checks_passed |
| FINISHED | - | GH.Issue:closed |
| FAILED | FAILED_JULES | Jules.Session:failed OR Jules.Session:error |
| | FAILED_PR | GH.PR:checks_failed |
end legend

@enduml
