@startuml
title Task State derivation from External Peers

package "External Peers" {
    state "GH.Issue" as GHI {
        [*] --> Open
        Open --> Closed
    }

    state "Jules.Session" as Jules {
        [*] --> None
        None --> researching
        researching --> planning
        planning --> coding
        coding --> testing
        testing --> finished

        researching --> failed
        planning --> failed
        coding --> failed
        testing --> failed
    }

    state "GH.PullRequest" as PR {
        [*] --> NoPR
        NoPR --> OpenPR
        OpenPR --> Merged
    }

    state "GH.PR.Checks" as Checks {
        [*] --> Pending
        Pending --> success
        Pending --> failure
    }
}

state "Unified Task State" as Unified {
    state CREATED #lightgrey

    state PROCESSING #lightblue {
        state QUEUED
        state ANALYZING
        state PLANNING
        state EXECUTING #yellow
        state VERIFYING #orange
    }

    state READY #lightgreen

    state FINISHED #green

    state FAILED #red {
        state JULES_FAILED
        state PR_FAILED
    }
}

GHI -[dashed]-> Unified : "influence"
Jules -[dashed]-> Unified : "influence"
PR -[dashed]-> Unified : "influence"
Checks -[dashed]-> Unified : "influence"

note bottom of Unified
  State is derived from the collection of External Peers.
  - READY if PR:Open AND Checks:success
  - FINISHED if GHI:Closed OR PR:Merged
end note

@enduml
